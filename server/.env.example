# SerpApi key — get one at https://serpapi.com/manage-api-key
SERP_API_KEY=your_serpapi_key_here

# HTTP port the API listens on
PORT=3000

# Allowed browser origin for CORS (the Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# Default Google locale for image search (optional)
SERPAPI_LOCATION=Mexico
SERPAPI_GOOGLE_DOMAIN=google.com.mx
SERPAPI_HL=es
SERPAPI_GL=mx
